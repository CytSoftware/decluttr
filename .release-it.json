{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "assets": [
      "apps/extension/decluttr-chrome.zip",
      "apps/extension/decluttr-firefox.zip"
    ]
  },
  "npm": false,
  "hooks": {
    "before:bump": "node scripts/sync-versions.js ${version}",
    "after:bump": "pnpm --filter @decluttr/extension package:all"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md",
      "header": "# Changelog"
    }
  }
}
