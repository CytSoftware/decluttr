# Ghost CMS (optional)
# Used by the /blog and /blog/:slug pages. Without these set, blog pages render
# a graceful empty state and everything else keeps working.
#
# These are Vite env vars — they are baked into the client bundle at build time.
# The Content API key is read-only and designed for public client-side use.
# See https://ghost.org/docs/content-api/
VITE_GHOST_URL=https://your-ghost-instance.com
VITE_GHOST_CONTENT_API_KEY=your_content_api_key_here

# Tag filter applied to the posts list. Defaults to "decluttr" if unset.
VITE_GHOST_TAG=decluttr
