{
  "name": "decluttr",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "dev:extension:chrome": "pnpm --filter @decluttr/extension dev:chrome",
    "dev:extension:firefox": "pnpm --filter @decluttr/extension dev:firefox",
    "build:extension": "pnpm --filter @decluttr/extension build:all",
    "dev:landing": "pnpm --filter @decluttr/landing dev",
    "release": "release-it"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "release-it": "^19.2.4",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.32.1"
}
