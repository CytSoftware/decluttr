{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:chrome": {
      "cache": false,
      "persistent": true
    },
    "dev:firefox": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
