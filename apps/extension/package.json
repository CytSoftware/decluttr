{
  "name": "@decluttr/extension",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "pnpm build:chrome && pnpm build:firefox",
    "dev:chrome": "cross-env BROWSER=chrome vite dev",
    "dev:firefox": "cross-env BROWSER=firefox vite dev",
    "build:chrome": "cross-env BROWSER=chrome vite build",
    "build:firefox": "cross-env BROWSER=firefox vite build",
    "build:all": "pnpm build:chrome && pnpm build:firefox",
    "package:chrome": "cd dist/chrome && zip -r ../../decluttr-chrome.zip .",
    "package:firefox": "cd dist/firefox && zip -r ../../decluttr-firefox.zip .",
    "package:all": "pnpm build:all && pnpm package:chrome && pnpm package:firefox"
  },
  "dependencies": {
    "@decluttr/types": "workspace:*",
    "@decluttr/ui": "workspace:*",
    "@react-spring/web": "^9.7.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-tinder-card": "^1.6.4",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@decluttr/config": "workspace:*",
    "@decluttr/tsconfig": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.12.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^6.0.0",
    "vite-plugin-web-extension": "^4.0.0"
  }
}
